{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "src/data/posts.json"
    },
    "api/ssr.ts": {
      "includeFiles": "src/data/posts.json, dist/base.html"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/api/ssr.ts"
    }
  ],
  "env": {
    "NODE_ENV": "vercel"
  }
}